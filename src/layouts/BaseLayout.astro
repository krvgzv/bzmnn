---
const {
  title = 'Безымянный сайт',
  description = 'Описание сайта',
  noindex = false,
} = Astro.props;

import Header from "../components/Header.astro";
const normalizedPath =
  Astro.url.pathname === "/index.html"
    ? "/"
    : Astro.url.pathname.replace(/\/index\.html$/, "/");

const canonical = new URL(normalizedPath, Astro.site);
const GA_ID = 'G-KM4HXM8FLP';
interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const siteUrl = 'https://bzmnn.site';
const pageTitle = title;
const pageDescription = description;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="google-site-verification" content="K5Fop5vjUt96Ci4EkNVX3N_qpk4brVoFaj5w6hlJSek" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription}/>
    <link rel="canonical" href={canonical.href} />
    <!-- /Redirects counter -->
<script is:inline>
  const { pathname, search, hash } = window.location;

  if (pathname === "/index.html") {
    window.location.replace("/" + search + hash);
  } else if (pathname.endsWith("/index.html")) {
    window.location.replace(
      pathname.replace(/\/index\.html$/, "/") + search + hash,
    );
  }
</script>
<!-- /Redirects counter -->
<!-- GA counter -->
<script
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
