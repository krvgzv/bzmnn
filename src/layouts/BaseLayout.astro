---
const { title = "Мой сайт" } = Astro.props;
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-container">
        <div class="footer-block">
          <nav class="footer-nav" aria-label="Навигация в подвале">
            <a href="/seo/">Основы SEO</a>
            <a href="/seo/analitika/">Аналитика</a>
          </nav>
        </div>

        <div class="footer-block">
          <a href="/seo/vnutrennyaya-optimizaciya/" class="footer-title">
            Внутренняя оптимизация
          </a>
          <nav class="footer-nav" aria-label="Навигация в подвале">
            <a href="/seo/vnutrennyaya-optimizaciya/tehnicheskiy-audit/">
              Технический аудит
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/ssylki/">Ссылки</a>
            <a href="/seo/vnutrennyaya-optimizaciya/struktura-sayta/">
              Структура сайта
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/kody-otveta/">
              Коды ответа
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/indeksaciya/">
              Индексация
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/karta-sayta/">
              Карта сайта
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/robots-txt/">
              Файл robots.txt
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/meta-tegi/">
              Мета-теги
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/mikrorazmetka/">
              Микроразметка
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/protokoly-bezopasnosti/">
              Протоколы безопасности
            </a>
            <a
              href="/seo/vnutrennyaya-optimizaciya/skorost-zagruzki-stranic/"
            >
              Скорость загрузки страниц
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/udobstvo-interfeysa/">
              Удобство интерфейса
            </a>
            <a href="/seo/vnutrennyaya-optimizaciya/kontent/">Контент</a>
          </nav>
        </div>

        <div class="footer-block">
          <a href="/seo/vneshnyaya-optimizaciya/" class="footer-title">
            Внешняя оптимизация
          </a>
          <nav class="footer-nav" aria-label="Навигация в подвале">
            <a href="/seo/vneshnyaya-optimizaciya/ssylochnyy-profil/">
              Ссылочный профиль
            </a>
            <a href="/seo/vneshnyaya-optimizaciya/linkbilding/">
              Линкбилдинг
            </a>
            <a
              href="/seo/vneshnyaya-optimizaciya/nakrutka-povedencheskih-faktorov/"
            >
              Накрутка поведенческих факторов
            </a>
            <a
              href="/seo/vneshnyaya-optimizaciya/upravlenie-reputaciey-v-internete/"
            >
              Управление репутацией в интернете
            </a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: Arial, sans-serif;
    background: #f7f7f7;
    color: #222222;
  }

  main {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 24px 16px;
    flex: 1;
  }

  footer {
    background: #ffffff;
    border-top: 1px solid #dddddd;
    padding: 24px 16px;
  }

  .footer-container {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .footer-block {
    min-width: 0;
  }

  .footer-title {
    display: inline-block;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  a {
    color: #000000;
    text-decoration: none;
  }

  a:hover {
    color: #1d4ed8;
  }

  main :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  main :global(pre) {
    padding: 16px;
    margin: 24px 0;
    overflow-x: auto;
    border-radius: 10px;
    background: #f3f4f6;
    color: #111827;
    font-size: 20px !important;
    line-height: 1.7;
  }

  main :global(pre code) {
    font-family:
      "Fira Code", "JetBrains Mono", Consolas, Monaco, "Courier New",
      monospace;
    font-size: inherit !important;
    color: inherit;
  }

  main :global(:not(pre) > code) {
    background: #e5e7eb;
    color: #111827;
    padding: 2px 6px;
    border-radius: 6px;
    font-family:
      "Fira Code", "JetBrains Mono", Consolas, Monaco, "Courier New",
      monospace;
    font-size: 18px !important;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
    }
  }
</style>