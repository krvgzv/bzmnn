<style>
  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    font-family: Arial, sans-serif;
    background: #f7f7f7;
    color: #222222;
  }

  main {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 24px 16px;
    flex: 1;
  }

  footer {
    background: #ffffff;
    border-top: 1px solid #dddddd;
    padding: 24px 16px;
  }

  .footer-container {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .footer-block {
    min-width: 0;
  }

  .footer-title {
    display: inline-block;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  a {
    color: #000000;
    text-decoration: none;
  }

  a:hover {
    color: #1d4ed8;
  }

  main :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  main :global(pre) {
    padding: 16px;
    margin: 24px 0;
    overflow-x: auto;
    border-radius: 10px;
    background: #f3f4f6;
    color: #111827;
    font-size: 20px !important;
    line-height: 1.7;
  }

  main :global(pre code) {
    font-family:
      "Fira Code", "JetBrains Mono", Consolas, Monaco, "Courier New",
      monospace;
    font-size: inherit !important;
    color: inherit;
  }

  main :global(:not(pre) > code) {
    background: #e5e7eb;
    color: #111827;
    padding: 2px 6px;
    border-radius: 6px;
    font-family:
      "Fira Code", "JetBrains Mono", Consolas, Monaco, "Courier New",
      monospace;
    font-size: 18px !important;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
    }
  }
</style>